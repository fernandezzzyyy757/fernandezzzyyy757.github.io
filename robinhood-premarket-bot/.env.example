# Copy this file to .env and fill in your real values. Never commit .env.

# Robinhood login (unofficial API via robin_stocks - see README for ToS risk)
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=

# Finnhub API key (free tier works to start) - https://finnhub.io/register
FINNHUB_API_KEY=

# Safety switch. Keep true until you've watched the bot run for a while.
# When true, the bot does everything (scan, score, propose, "fill") except
# actually call Robinhood's order endpoints - it logs what it would have done.
DRY_RUN=true
