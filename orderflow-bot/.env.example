# Discord webhook URL (Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxx/xxxxxxxx

# Yahoo Finance ticker for the gold futures continuous contract
TICKER=GC=F

# How often to poll for new bars, in seconds
POLL_INTERVAL_SECONDS=60

# How many recent 1-minute bars to keep in the rolling window for VPOC/percentile calcs
LOOKBACK_BARS=180
